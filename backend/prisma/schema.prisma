enum	Role {
	USER
	MOD
	ADMIN
}

enum	FriendshipStatus{
    PENDING
    ACCEPTED
    BLOCKED
}

enum	NotificationType {
    LIKE
    COMMENT
    BATTLE_WIN
    FRIEND_REQUEST
}

enum	BattleStatus {
    UPCOMING
    ACTIVE
    FINISHED
    CANCELLED
}

enum  ModerationType {
	DELETE_ANY_POST
	CHANGE_ROLE
	BAN_USER
	CREATE_TOURNAMENT
	REVIEW_REPORT
}

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// @ symbols are Prisma directives > they define rules that apply to the column
model User {
	id			Int     	@id @default(autoincrement())	//@id > clé primaire de la table 
	//	Each table MUST have a primary key. This key uniquely identifies each row.
	email		String  	@unique
	username	String		@unique
	password 	String
	createdAt	DateTime	@default(now())
	updatedAt	DateTime	@default(now()) @updatedAt

    role	    Role	@default(USER)
	bannedAt	DateTime?

    profile				    Profile?
    posts			        Post[]
    likes			        Like[]
    comments                Comment[]
    conversations           Conversation[]	        @relation("UserConversations")
    messages		        Message[]	            @relation("MessageSender")
    friendRequestSent	  	Friendship[]		    @relation("FriendRequester")
    friendRequestReceived	Friendship[]	    	@relation("FriendAddresse")
    battleParticipants		BattleParticipant[]
    notifications           Notification[]
    battlesWon              Battle[]                @relation("BattleWinner")
    battlesCreated          Battle[]                @relation("CreatedBattles")
	
	// relations for ModerationLog
	moderationLogsAuthored ModerationLog[]          @relation("ActorRelation")
  	moderationLogsTargeted ModerationLog[]          @relation("TargetUserRelation")
}

model	Profile {
    //	primary key
    id			Int		@id @default(autoincrement())
    avatarUrl	String?
    coverUrl	String?
    bio			String?
    displayName	String?

    //	foreign key
    userId		Int		@unique

    user		User	@relation(fields: [userId], references: [id])
}

model	Post {
	id			Int			@id @default(autoincrement())
	title		String
	imageUrl	String
	caption		String?
	createdAt	DateTime	@default(now())
	updatedAt	DateTime	@default(now()) @updatedAt

    authorId	Int
    author		User	@relation(fields: [authorId], references: [id])

	likes				Like[]
	comments			Comment[]
	battleParticipants	BattleParticipant[]
	postTags			PostTag[]

	// relation for ModerationLog
	moderationLogs ModerationLog[] @relation("TargetPostRelation")
}

model	Like {
    id		    Int	@id @default(autoincrement())

    userId  	Int
    postId	    Int
    battleId    Int?
    createdAt   DateTime @default(now())

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

    //	A user can only like a specific post once (no duplicate likes)
    //	@@ > applies a rule at the model level, not just a single field
    @@unique([userId, postId])
}

model	Comment {
    id			Int			@id @default(autoincrement())
    content		String
    createdAt	DateTime	@default(now())

	userId		Int
	postId		Int
	parentId	Int?

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	parent Comment? @relation("Comment replies", fields: [parentId], references: [id])
	replies Comment[] @relation("Comment replies")
}

model	Conversation {
    id			Int			@id @default(autoincrement())
    createdAt	DateTime	@default(now())

    users	User[]	@relation("UserConversations")

    messages	Message[]
}

model	Message {
    id			Int			@id @default(autoincrement())
    content		String
    createdAt	DateTime	@default(now())

    senderId		Int
    conversationId	Int

    sender			User			@relation("MessageSender", fields: [senderId], references: [id])
    conversation	Conversation	@relation(fields: [conversationId], references: [id])
}

model Friendship {
  id	Int	@id @default(autoincrement())

  requesterId	Int
  addresseId	Int

  requester	User	@relation("FriendRequester", fields: [requesterId], references: [id])
  addresse	User	@relation("FriendAddresse", fields: [addresseId], references: [id])

  status FriendshipStatus	@default(PENDING)

  @@unique([requesterId, addresseId])
}

model Battle {
  id        	Int			@id @default(autoincrement())
  theme     	String
  maxPlayers	Int?
  rules			  String?
  description	String?

  createdAt	DateTime	@default(now())
  startsAt	DateTime
  endsAt    DateTime

  status    BattleStatus  @default(UPCOMING)
  winnerId  Int?
  winner    User?         @relation("BattleWinner", fields: [winnerId], references: [id])

  participants BattleParticipant[]

  createdById Int?
  createdBy   User? @relation("CreatedBattles", fields: [createdById], references: [id])
  
  // relation for ModerationLog
  moderationLogs ModerationLog[] @relation("TargetBattleRelation")
}

model BattleParticipant {
    id			    Int	@id @default(autoincrement())
    battleId  	Int
    userId		  Int
    postId		  Int
    submittedAt DateTime?

	battle	Battle	@relation(fields: [battleId], references: [id])
	user	User	@relation(fields: [userId], references: [id])
	post	Post?	@relation(fields: [postId], references: [id], onDelete: Cascade)

	@@unique([battleId, userId])
}

model ModerationLog {
	id             Int             @id @default(autoincrement())
	action         ModerationType
	actorId        Int
	actor          User            @relation("ActorRelation", fields: [actorId], references: [id])
	targetUserId   Int?
	targetUser     User?           @relation("TargetUserRelation", fields: [targetUserId], references: [id])
	targetPostId   Int?
	targetPost     Post?           @relation("TargetPostRelation", fields: [targetPostId], references: [id], onDelete: SetNull)
	targetBattleId Int?
	targetBattle   Battle?         @relation("TargetBattleRelation", fields: [targetBattleId], references: [id])
	createdAt      DateTime        @default(now())
}

model Notification {
    id		Int @id @default(autoincrement())
    type	NotificationType
    isRead 	Boolean @default(false)

    userId	Int
    user	User	@relation(fields: [userId], references: [id])

    createdAt DateTime @default(now())
}

model Tag {
    id		Int		@id @default(autoincrement())
    name	String	@unique

    postTags	PostTag[]
}

model PostTag {
    postId	Int
    tagId	Int

	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)
	tag		Tag		@relation(fields: [tagId], references: [id])

    @@unique([postId, tagId])
}