enum	Role {
	USER
	MOD
	ADMIN
}

enum	FriendshipStatus{
	PENDING
	ACCEPTED
	BLOCKED
}

enum	NotificationType {
	LIKE
	COMMENT
	BATTLE_WIN
	FRIEND_REQUEST
}

enum  ModerationType {
	DELETE_ANY_POST
	CHANGE_ROLE
	BAN_USER
	CREATE_TOURNAMENT
	REVIEW_REPORT
}

enum ReportType { 
	SPAM
	HARASSMENT
	INAPPROPRIATE_CONTENT
	OTHER
}

generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

// @ symbols are Prisma directives > they define rules that apply to the column
model User {
	id			Int     	@id @default(autoincrement())	//@id > clé primaire de la table 
	//	Each table MUST have a primary key. This key uniquely identifies each row.
	email		String  	@unique
	username	String		@unique
	password 	String
	createdAt	DateTime	@default(now())
	updatedAt	DateTime	@default(now()) @updatedAt

	role		Role	@default(USER)
	bannedAt	DateTime?

	profile					Profile?
	posts					Post[]
	likes					Like[]
	comments				Comment[]
	conversations			Conversation[]		@relation("UserConversations")
	messages				Message[]			@relation("MessageSender")
	friendRequestSent		Friendship[]		@relation("FriendRequester")
	friendRequestReceived	Friendship[]		@relation("FriendAddresse")
	battleParticipants		BattleParticipant[]
	votes					Vote[]
	notifications			Notification[]
	
	// relations for ModerationLog
	moderationLogsAuthored ModerationLog[] @relation("ActorRelation")
  	moderationLogsTargeted ModerationLog[] @relation("TargetUserRelation")

	// relations for Reports

	reportsAuthored   Report[] @relation("ReporterRelation")    // reports creat by the user
	reportsAgainst    Report[] @relation("ReportedUserRelation") // reports agaist the user
	reportsHandled    Report[] @relation("ModeratorRelation")   // reports handled by the user
}

model	Profile {
	//	primary key
	id			Int		@id @default(autoincrement())
	avatarUrl	String?
	coverUrl	String?
	bio			String?
	displayName	String?

	//	foreign key
	userId		Int		@unique

	user		User	@relation(fields: [userId], references: [id])
}

model	Post {
	id			Int			@id @default(autoincrement())
	title		String
	imageUrl	String
	caption		String?
	createdAt	DateTime	@default(now())
	updatedAt	DateTime	@default(now()) @updatedAt

	authorId	Int
	author		User	@relation(fields: [authorId], references: [id])

	likes				Like[]
	comments			Comment[]
	battleParticipants	BattleParticipant[]
	votes				Vote[]
	postTags			PostTag[]

	// relation for ModerationLog
	moderationLogs ModerationLog[] @relation("TargetPostRelation")
	
	// relation for Reports
	reports     Report[] @relation("ReportedPostRelation") //
}

model	Like {
	id		Int	@id @default(autoincrement())

	userId	Int
	postId	Int

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	//	A user can only like a specific post once (no duplicate likes)
	//	@@ > applies a rule at the model level, not just a single field
	@@unique([userId, postId])
}

model	Comment {
	id			Int			@id @default(autoincrement())
	content		String
	createdAt	DateTime	@default(now())

	userId		Int
	postId		Int
	parentId	Int?

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	parent Comment? @relation("Comment replies", fields: [parentId], references: [id])
	replies Comment[] @relation("Comment replies")
}

model	Conversation {
	id			Int			@id @default(autoincrement())
	createdAt	DateTime	@default(now())

	users	User[]	@relation("UserConversations")

	messages	Message[]
}

model	Message {
	id			Int			@id @default(autoincrement())
	content		String
	createdAt	DateTime	@default(now())

	senderId		Int
	conversationId	Int

	sender			User			@relation("MessageSender", fields: [senderId], references: [id])
	conversation	Conversation	@relation(fields: [conversationId], references: [id])
}

model Friendship {
  id	Int	@id @default(autoincrement())

  requesterId	Int
  addresseId	Int

  requester	User	@relation("FriendRequester", fields: [requesterId], references: [id])
  addresse	User	@relation("FriendAddresse", fields: [addresseId], references: [id])

  status FriendshipStatus	@default(PENDING)

  @@unique([requesterId, addresseId])
}

model Battle {
  id        Int			@id @default(autoincrement())
  theme     String
  createdAt	DateTime	@default(now())
  endsAt    DateTime

  participants BattleParticipant[]
  votes        Vote[]
  
  // relation for ModerationLog
  moderationLogs ModerationLog[] @relation("TargetBattleRelation")
}

model BattleParticipant {
	id			Int	@id @default(autoincrement())
	battleId 	Int
	userId		Int
	postId		Int

	battle	Battle	@relation(fields: [battleId], references: [id])
	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	@@unique([battleId, userId])
}

model Vote {
	id			Int @id @default(autoincrement())
	battleId	Int	// for which battle is this vote
	voterId		Int
	postId		Int

	battle	Battle	@relation(fields: [battleId], references: [id])
	voter	User	@relation(fields: [voterId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	@@unique([battleId, voterId])
}

model ModerationLog {
	id             Int             @id @default(autoincrement())
	action         ModerationType
	actorId        Int
	actor          User            @relation("ActorRelation", fields: [actorId], references: [id])
	targetUserId   Int?
	targetUser     User?           @relation("TargetUserRelation", fields: [targetUserId], references: [id])
	targetPostId   Int?
	targetPost     Post?           @relation("TargetPostRelation", fields: [targetPostId], references: [id], onDelete: SetNull)
	targetBattleId Int?
	targetBattle   Battle?         @relation("TargetBattleRelation", fields: [targetBattleId], references: [id])
	createdAt      DateTime        @default(now())
}

model Report {
	id						Int       @id @default(autoincrement())
	reporterId			Int
	reporter			User        @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
	reportedUserId 		Int?		// reported user
	reportedUser		User?       @relation("ReportedUserRelation", fields: [reportedUserId], references: [id], onDelete: Cascade)
	reportedPostId		Int?		// reported post
	reportedPost		Post?       @relation("ReportedPostRelation", fields: [reportedPostId], references: [id], onDelete: Cascade)
	reportCategory		ReportType
	reportDescription	String?
	moderatorMessage	String?
	createdAt			DateTime  @default(now())
	handled				Boolean   @default(false)
	handledById			Int?
	handledBy			User? @relation("ModeratorRelation", fields: [handledById], references: [id])

	@@unique([reporterId, reportedPostId])
}

model Notification {
	id		Int @id @default(autoincrement())
	type	NotificationType
	isRead 	Boolean @default(false)

	userId	Int
	user	User	@relation(fields: [userId], references: [id])

	createdAt DateTime @default(now())
}

model Tag {
	id		Int		@id @default(autoincrement())
	name	String	@unique

	postTags	PostTag[]
}

model PostTag {
	postId	Int
	tagId	Int

	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)
	tag		Tag		@relation(fields: [tagId], references: [id])

	@@unique([postId, tagId])
}