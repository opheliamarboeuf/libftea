{{! src/mail/templates/report-confirmation.hbs }}
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body style="font-family: system-ui, Avenir, Helvetica, Arial, sans-serif; background-color: #f5f5f5; margin: 0; padding: 20px; line-height: 1.5;">

    <div style="background-color: #ffffff; border-radius: 10px; padding: 30px; max-width: 600px; margin: 0 auto; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.214);">

      <!-- Header -->
      <div style="border-bottom: 1px solid #e0e0e0; padding-bottom: 20px; margin-bottom: 20px;">
        <h2 style="color: #1a1a1a; margin: 0 0 4px 0; font-size: 1.2rem; font-weight: bold;">Report Confirmation</h2>
        <p style="margin: 0; font-size: 0.8rem; color: #555; font-weight: 500;">The {{appName}} team</p>
      </div>

      <!-- Greeting -->
      <p style="color: #333; margin: 15px 0; font-size: 0.9rem;">
        Hello <strong style="color: #1a1a1a; font-weight: 600;">{{username}}</strong>,
      </p>

      <!-- Confirmation notice -->
      <div style="background-color: #f5f5f5; border-left: 3px solid #1a1a1a; padding: 12px 16px; border-radius: 4px; margin: 20px 0;">
        <p style="color: #1a1a1a; margin: 0; font-size: 0.9rem; font-weight: 600;">
          Your report has been successfully submitted.
        </p>
      </div>

      <!-- Body -->
      <p style="color: #333; margin: 20px 0; font-size: 0.9rem;">
        Here is a summary of your report:
      </p>

      <!-- Report details -->
      <div style="background-color: #f5f5f5; border-radius: 8px; padding: 16px; margin: 10px 0;">
        <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem; table-layout: fixed;">
          <tr>
            <td style="color: #555; padding: 6px 0; width: 120px;">Report ID</td>
            <td style="color: #1a1a1a; font-weight: 600; padding: 6px 0; word-break: break-word; overflow-wrap: break-word;">#{{reportId}}</td>
          </tr>
          <tr style="border-top: 1px solid #e0e0e0;">
            <td style="color: #555; padding: 6px 0; width: 120px;">Category</td>
            <td style="color: #1a1a1a; font-weight: 600; padding: 6px 0; word-break: break-word; overflow-wrap: break-word;">{{category}}</td>
          </tr>
          {{#if description}}
          <tr style="border-top: 1px solid #e0e0e0;">
            <td style="color: #555; padding: 6px 0; vertical-align: top; width: 120px;">Description</td>
            <td style="color: #1a1a1a; padding: 6px 0; word-break: break-word; overflow-wrap: break-word;">{{description}}</td>
          </tr>
          {{/if}}
        </table>
      </div>

      <p style="color: #333; font-size: 0.9rem; margin: 20px 0;">
        Our moderation team will review it as soon as possible. You will not receive further updates unless additional information is required.
      </p>

      <p style="color: #555; font-size: 0.9rem; margin: 20px 0;">
        Thank you for your understanding.
      </p>

      <!-- Footer -->
      <div style="border-top: 1px solid #e0e0e0; padding-top: 20px; margin-top: 30px; text-align: center;">
        <p style="color: #555; font-size: 0.8rem; margin: 5px 0; font-weight: 500;">The {{appName}} team</p>
      </div>

    </div>
  </body>
</html>