{{! src/mail/templates/2fa-code.hbs }}
<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>
  <body style="font-family: system-ui, Avenir, Helvetica, Arial, sans-serif; background-color: #f5f5f5; margin: 0; padding: 20px; line-height: 1.5;">

    <div style="background-color: #ffffff; border-radius: 10px; padding: 30px; max-width: 600px; margin: 0 auto; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.214);">

      <!-- Header -->
      <div style="border-bottom: 1px solid #e0e0e0; padding-bottom: 20px; margin-bottom: 20px;">
        <h2 style="color: #1a1a1a; margin: 0 0 4px 0; font-size: 1.2rem; font-weight: bold;">Two-Factor Authentication</h2>
        <p style="margin: 0; font-size: 0.8rem; color: #555; font-weight: 500;">The {{appName}} team</p>
      </div>

      <!-- Greeting -->
      <p style="color: #333; margin: 15px 0; font-size: 0.9rem;">
        Hello <strong style="color: #1a1a1a; font-weight: 600;">{{username}}</strong>,
      </p>

      <!-- Info notice -->
      <div style="background-color: #f5f5f5; border-left: 3px solid #1a1a1a; padding: 12px 16px; border-radius: 4px; margin: 20px 0;">
        <p style="color: #1a1a1a; margin: 0; font-size: 0.9rem; font-weight: 600;">
          A login attempt was made on your account.
        </p>
      </div>

      <!-- Code -->
      <p style="color: #333; font-size: 0.9rem; margin: 20px 0 10px 0;">
        Use the code below to complete your sign-in:
      </p>

      <div style="background-color: #f5f5f5; border-radius: 8px; padding: 24px 16px; margin: 10px 0; text-align: center;">
        <p style="font-size: 2rem; font-weight: 700; letter-spacing: 12px; color: #1a1a1a; margin: 0;">{{code}}</p>
      </div>

      <p style="color: #555; font-size: 0.9rem; margin: 16px 0;">
        This code will expire in <strong style="color: #1a1a1a;">{{expiresIn}}</strong>.
      </p>

      <p style="color: #555; font-size: 0.9rem; margin: 20px 0;">
        If you did not attempt to log in, please secure your account immediately by changing your password.
      </p>

      <!-- Footer -->
      <div style="border-top: 1px solid #e0e0e0; padding-top: 20px; margin-top: 30px; text-align: center;">
        <p style="color: #555; font-size: 0.8rem; margin: 5px 0; font-weight: 500;">The {{appName}} team</p>
      </div>

    </div>
  </body>
</html>