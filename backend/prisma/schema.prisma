generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

enum BattleStatus {
	UPCOMING
	ACTIVE
	FINISHED
	CANCELLED
}

enum FriendshipStatus {
	PENDING
	ACCEPTED
	BLOCKED
}

enum ModerationLogType {
	DELETE_ANY_POST
	CHANGE_ADMIN_ROLE
	CHANGE_MOD_ROLE
	BAN_USER
	UNBAN_USER
	REVIEW_USER_REPORT
	REVIEW_POST_REPORT
	CREATE_TOURNAMENT
}

enum Role {
	USER
	ADMIN
	MOD
}

enum ReportType { 
	SPAM
	HARASSMENT
	INAPPROPRIATE_CONTENT
	OTHER
}

enum ReportStatus {
	PENDING
	ASSIGNED
	ACCEPTED
	REJECTED
}

enum NotificationType {
	LIKE
	COMMENT
	COMMENT_REPLY
	NEW_BATTLE
	BATTLE_WIN
	BATTLE_END
	FRIEND_REQUEST
	FRIEND_REQUEST_ACCEPTED
	POST
	ADMIN_PROMOTE
	MOD_PROMOTE
	DEMOTED
}

model User {
	id                                             Int                 @id @default(autoincrement())
	email                                          String              @unique
	twoFactorEnabled							   Boolean			   @default(false)
	twoFactorCode								   String?
	twoFactorExpires 							   DateTime?
	githubId String?							   @unique
	createdAt                                      DateTime            @default(now())
	password                                       String
	role                                           Role                @default(USER)
	username                                       String              @unique
	updatedAt                                      DateTime            @default(now())
	bannedAt                                       DateTime?
	Battle_Battle_createdByIdToUser                Battle[]            @relation("Battle_createdByIdToUser")
	Battle_Battle_winnerIdToUser                   Battle[]            @relation("Battle_winnerIdToUser")
	BattleParticipant                              BattleParticipant[]
	Comment                                        Comment[]
	friendRequestReceived							Friendship[]        @relation("friendRequestReceived")
	friendRequestSent								Friendship[]        @relation("friendRequestSent")
	Like                                           Like[]
	Message                                        Message[]
	Notification                                   Notification[]
	posts                                          Post[]
	profile                                        Profile?
	Conversation                                   Conversation[]      @relation("UserConversations")

	// relation for UserHiddenForUser
	hiddenUsers    UserHiddenForUser[] @relation("UserHider") // list of users hidden by the current user
  	hiddenByUsers  UserHiddenForUser[] @relation("UserTarget") // list of users that hid the current user

	// relation for PostHiddenForUser
	hiddenPosts		PostHiddenForUser[]

	// relations for ModerationLog
	moderationLogsAuthored ModerationLog[] @relation("ActorRelation")
  	moderationLogsTargeted ModerationLog[] @relation("TargetUserRelation")

	// relations for Reports

	reportsAuthored   Report[] @relation("ReporterRelation")    // reports creat by the user
	reportsAgainst    Report[] @relation("ReportedUserRelation") // reports agaist the user
	reportsHandled    Report[] @relation("ModeratorRelation")   // reports handled by the user
}

model UserHiddenForUser {
	id      Int   @id @default(autoincrement())
	userId  Int
	targetUserId  Int

	user		User @relation("UserHider", fields: [userId], references: [id], onDelete: Cascade)
	targetUser	User @relation("UserTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

	@@unique([targetUserId, userId])
}

model Battle {
	id                            Int                 @id @default(autoincrement())
	theme                         String
	createdAt                     DateTime            @default(now())
	endsAt                        DateTime
	startsAt                      DateTime
	createdById                   Int?
	description                   String?
	maxPlayers                    Int?
	rules                         String?
	status                        BattleStatus        @default(UPCOMING)
	winnerId                      Int?
	User_Battle_createdByIdToUser User?               @relation("Battle_createdByIdToUser", fields: [createdById], references: [id])
	winner						    User?               @relation("Battle_winnerIdToUser", fields: [winnerId], references: [id])
	BattleParticipant             BattleParticipant[]
	moderationLogs ModerationLog[] @relation("TargetBattleRelation")
	NotifSent					  Boolean			   @default(false)
}

model BattleParticipant {
	id          Int       @id @default(autoincrement())
	battleId    Int
	userId      Int
	postId      Int
	submittedAt DateTime?
	Battle      Battle    @relation(fields: [battleId], references: [id])
	post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
	user        User      @relation(fields: [userId], references: [id])

	@@unique([battleId, userId])
}

model	Comment {
	id			Int			@id @default(autoincrement())
	content		String
	createdAt	DateTime	@default(now())
	deletedAt   DateTime?
	bannedDeletion    Boolean 			  @default(false)

	userId		Int
	postId		Int
	parentId	Int?

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id], onDelete: Cascade)

	parent Comment? @relation("Comment replies", fields: [parentId], references: [id])
	replies Comment[] @relation("Comment replies")
}

model Conversation {
	id        Int       @id @default(autoincrement())
	createdAt DateTime  @default(now())
	Message   Message[]
	User      User[]    @relation("UserConversations")
}

model Friendship {
	id          Int              @id @default(autoincrement())
	requesterId Int
	addresseId  Int
	status      FriendshipStatus @default(PENDING)
	requester   User             @relation("friendRequestSent", fields: [requesterId], references: [id])
	addresse    User             @relation("friendRequestReceived", fields: [addresseId], references: [id])

	@@unique([requesterId, addresseId])
}

model Like {
	id        Int      @id @default(autoincrement())
	userId    Int
	postId    Int
	battleId  Int?
	createdAt DateTime @default(now())
	Post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
	User      User     @relation(fields: [userId], references: [id])

	@@unique([userId, postId])
}

model Message {
	id             Int          @id @default(autoincrement())
	content        String
	createdAt      DateTime     @default(now())
	senderId       Int
	conversationId Int
	Conversation   Conversation @relation(fields: [conversationId], references: [id])
	User           User         @relation(fields: [senderId], references: [id])
  type					 String				@default("text")
  metadata Json?
}

model ModerationLog {
	id             Int             @id @default(autoincrement())
	action         ModerationLogType
	actorId        Int
	actor          User            @relation("ActorRelation", fields: [actorId], references: [id])
	targetUserId   Int?
	targetUser     User?           @relation("TargetUserRelation", fields: [targetUserId], references: [id])
	targetPostId   Int?
	targetPost     Post?           @relation("TargetPostRelation", fields: [targetPostId], references: [id], onDelete: SetNull)
	targetBattleId Int?
	targetBattle   Battle?         @relation("TargetBattleRelation", fields: [targetBattleId], references: [id])
	createdAt      DateTime        @default(now())
}

model Report {
	id						Int       @id @default(autoincrement())
	reporterId			Int
	reporter			User        @relation("ReporterRelation", fields: [reporterId], references: [id], onDelete: Cascade)
	reportedUserId 		Int?		// reported user
	reportedUser		User?       @relation("ReportedUserRelation", fields: [reportedUserId], references: [id], onDelete: Cascade)
	reportedPostId		Int?		// reported post
	reportedPost		Post?       @relation("ReportedPostRelation", fields: [reportedPostId], references: [id], onDelete: Cascade)
	reportCategory		ReportType
	reportDescription	String?
	moderatorMessage	String?
	createdAt			DateTime  @default(now())
	status				ReportStatus @default(PENDING)
	handledById			Int?
	handledBy			User? @relation("ModeratorRelation", fields: [handledById], references: [id])
	handledAt			DateTime?

	@@unique([reporterId, reportedPostId])
	@@unique([reporterId, reportedUserId])
}

model Notification {
	id        Int              @id @default(autoincrement())
	type      NotificationType
	isRead    Boolean          @default(false)
	userId    Int
	createdAt DateTime         @default(now())
	User      User             @relation(fields: [userId], references: [id])
	message   String           @default("")
	metadata  Json			   @default("{}")
}

model Post {
	id                Int                 @id @default(autoincrement())
	imageUrl          String
	caption           String?
	createdAt         DateTime            @default(now())
	authorId          Int
	title             String
	updatedAt         DateTime            @default(now())
	deletedAt		  DateTime?
	bannedDeletion    Boolean 			  @default(false)
	battleParticipants BattleParticipant[]
	Comment           Comment[]
	Like              Like[]
	author            User                @relation(fields: [authorId], references: [id])
	PostTag           PostTag[]
	
	// relation for PostHiddenForUser
	hiddenForUsers         PostHiddenForUser[]

	// relation for ModerationLog
	moderationLogs ModerationLog[] @relation("TargetPostRelation")
	
	// relation for Reports
	reports     Report[] @relation("ReportedPostRelation") //
}


model PostHiddenForUser {
	id      Int   @id @default(autoincrement())
	postId  Int
	userId  Int

	post    Post  @relation(fields: [postId], references: [id], onDelete: Cascade)
	user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)

	@@unique([postId, userId])
}

model PostTag {
	postId Int
	tagId  Int
	Post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
	Tag    Tag  @relation(fields: [tagId], references: [id])

	@@unique([postId, tagId])
}

model Profile {
	id          Int     @id @default(autoincrement())
	avatarUrl   String?
	bio         String?
	userId      Int     @unique
	coverUrl    String?
	User        User    @relation(fields: [userId], references: [id])
}

model Tag {
	id      Int       @id @default(autoincrement())
	name    String    @unique
	PostTag PostTag[]
}


