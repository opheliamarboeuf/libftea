generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "postgresql"
	url      = env("DATABASE_URL")
}

model User {
	id    		Int     	@id @default(autoincrement())
	email 		String  	@unique
	username	String		@unique
	password 	String
	createdAt	DateTime	@default(now())

	profile		Profile?	// optional field — a user can be created now and link a profile later
	posts		Post[]
	likes		Like[]
	comments	Comment[]
}

model	Profile {
	id			Int			@id @default(autoincrement())
	avatarUrl	String?
	bio			String?

	userId		Int			@unique
}

model	Post {
	id			Int
	imageUrl	String
	caption		String?
	createdAt	@default(now())

	authorId	Int
	author		User	@relation(fields: [authorId], references: [id])

	likes		Like[]
	comments	Comment[]
}

model	Like {
	id		Int

	userId	Int
	postId	Int

	user		User	@relation(fields: [userId], references: [id])
	post		Post	@relation(fields: [postId], references: [id])
}

model	Comment {
	id			Int			@id @default(autoincrement())
	content		String
	createdAt	DateTime	@default(now())

	userId		Int
	postId		Int

	user	User	@relation(fields: [userId], references: [id])
	post	Post	@relation(fields: [postId], references: [id])
}

model	Conversation {
	id			Int			@id @default(autoincrement())
	createdAt	DateTime	@default(now())

	user	User[]	@relation("UserConversations")
	message	Message[]
}